rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 週間献立アプリ用ルール
    // - 家族コード(familyId)を知っている匿名ユーザーが書き込み可
    // - 家族コードはアプリ起動時にユーザーが入力する共有秘密
    // - 機密情報（パスワード等）は扱わない前提
    // ============================================================
    function isSignedIn() { return request.auth != null; }

    // families/{familyId}: 家族情報（メンバー一覧）
    match /families/{familyId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;

      // profile/main: 家族プロフィール（メンバー・除外食材・備考）
      match /profile/{docId} {
        allow read, write: if isSignedIn();
      }

      // menus/{weekStart}: 週間献立（YYYY-MM-DD をキーに使う）
      match /menus/{menuId} {
        allow read, write: if isSignedIn();
      }

      // favorites/{recipeId}: お気に入りレシピ
      match /favorites/{recipeId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
